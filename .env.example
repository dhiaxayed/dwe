# Rename this file to .env.local and fill with your credentials.
# Values marked with <> must be replaced with your own information.

# --- SMTP transport (required for production emails) ---
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=<smtp-username>
SMTP_PASSWORD=<smtp-password>

# The address that appears in the "From" field when prospects receive the confirmation email.
MAIL_FROM="Your Studio <contact@your-domain.com>"

# Where you want to receive copies of every incoming lead.
CONTACT_NOTIFICATION_EMAIL=you@your-domain.com

# --- Branding / public metadata ---
BRAND_NAME="Your Studio"
BRAND_LOGO_URL="https://your-domain.com/logo.png"
# Optional: serve a logo from /public without hosting it elsewhere
BRAND_LOGO_FILE="dwe-logo.png"
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Public values consumed by the marketing site (safe to bundle client-side).
NEXT_PUBLIC_CONTACT_EMAIL=contact@your-domain.com
NEXT_PUBLIC_CONTACT_PHONE="+33 1 23 45 67 89"
